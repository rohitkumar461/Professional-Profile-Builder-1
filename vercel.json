{
  "outputDirectory": "artifacts/portfolio/dist/public",
  "buildCommand": "pnpm -w run build:vercel",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}