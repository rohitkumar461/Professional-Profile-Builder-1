{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node -e \"var f=require('fs');try{f.unlinkSync('package-lock.json')}catch(e){}try{f.unlinkSync('yarn.lock')}catch(e){};if(!(process.env.npm_config_user_agent||'').startsWith('pnpm/')){console.error('Use pnpm');process.exit(1)}\"",
    "build:vercel": "pnpm --filter @workspace/portfolio run build:vercel",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "dependencies": {
    "nodemailer": "^9.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.14",
    "@types/nodemailer": "^8.0.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
